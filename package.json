{
  "name": "spotify-mcp-server",
  "version": "0.1.0-dev",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "build:worker": "esbuild src/worker.ts --bundle --format=esm --outfile=dist/worker.js --platform=neutral",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "lint": "oxlint src",
    "lint:fix": "oxlint src --fix",
    "format": "prettier --write 'src/**/*.{ts,json,md}'",
    "format:check": "prettier --check 'src/**/*.{ts,json,md}'",
    "check": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@cloudflare/workers-types": "^4.20250620.0",
    "@hono/node-server": "^1.14.4",
    "@types/node": "^24.0.3",
    "@vitest/coverage-v8": "3.2.3",
    "dotenv": "^16.5.0",
    "esbuild": "^0.25.5",
    "oxlint": "^1.2.0",
    "prettier": "^3.5.3",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-mcp": "^0.0.12",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "@spotify/web-api-ts-sdk": "^1.2.0",
    "@typescript/native-preview": "7.0.0-dev.20250619.1",
    "hono": "^4.8.2",
    "neverthrow": "^8.2.0",
    "zod": "^3.25.67"
  }
}
